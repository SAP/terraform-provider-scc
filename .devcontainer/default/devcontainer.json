{
	"name": "Terraform Provider for SAP Cloud Connector",
	"image": "mcr.microsoft.com/devcontainers/go:dev-1.26",
	"features": {
		"ghcr.io/devcontainers/features/github-cli:1": {},
		"ghcr.io/devcontainers/features/terraform:1": {
			"tflint": "none",
			"terragrunt": "none"
		},
		"ghcr.io/robbert229/devcontainer-features/opentofu:1": {
			"version": "1.12.1"
		}
	},
	"customizations": {
		"vscode": {
			"settings": {},
			"extensions": [
				"golang.go",
				"HashiCorp.terraform",
				"ms-vscode.makefile-tools"
			]
		},
		"codespaces": {}
	},
	"postCreateCommand": "cp ./config/provider-config-local.txt ~/.terraformrc && bash ./.devcontainer/scripts/install-tflint.sh",
	"hostRequirements": {
		"memory": "4gb"
	},
	"remoteUser": "vscode"
}
